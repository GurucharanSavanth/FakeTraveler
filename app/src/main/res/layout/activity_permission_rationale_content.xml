<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/permission_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorSurface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <ImageView
            android:layout_width="@dimen/permission_illustration_size"
            android:layout_height="@dimen/permission_illustration_size"
            android:contentDescription="@string/Cd_PermissionIllustration"
            android:src="@drawable/ic_location_searching"
            app:tint="?attr/colorPrimary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:gravity="center"
            android:text="@string/Permission_Title"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="?attr/colorOnSurface" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:gravity="center"
            android:text="@string/Permission_Body"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_gap"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_permission_step"
                android:padding="@dimen/card_internal_padding"
                android:text="@string/Permission_Step1_Body"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="@color/colorOnWarningContainer" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:background="@drawable/bg_permission_step"
                android:padding="@dimen/card_internal_padding"
                android:text="@string/Permission_Step2_Body"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="@color/colorOnWarningContainer" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:background="@drawable/bg_permission_step"
                android:padding="@dimen/card_internal_padding"
                android:text="@string/Permission_Step3_Body"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="@color/colorOnWarningContainer" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/permission_open_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_gap"
            android:text="@string/Permission_CTA_OpenDevSettings"
            app:icon="@drawable/ic_settings" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/permission_already_done"
            style="@style/Widget.FakeTraveler.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/Permission_CTA_AlreadyDone" />
    </LinearLayout>
</ScrollView>
