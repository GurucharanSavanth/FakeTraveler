<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/spacing_lg">

    <TextView
        android:id="@+id/bookmark_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/Bookmark_Dialog_Title_Add"
        android:textAppearance="?attr/textAppearanceTitleLarge"
        android:textColor="?attr/colorOnSurface" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/bookmark_name_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        android:hint="@string/Bookmark_Dialog_Name_Hint"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusBottomEnd="@dimen/corner_small"
        app:boxCornerRadiusBottomStart="@dimen/corner_small"
        app:boxCornerRadiusTopEnd="@dimen/corner_small"
        app:boxCornerRadiusTopStart="@dimen/corner_small">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/bookmark_name_input"
            android:layout_width="match_parent"
            android:layout_height="@dimen/text_input_height"
            android:inputType="textCapWords"
            android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:orientation="horizontal">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/bookmark_lat_layout"
            android:layout_width="@dimen/size_zero"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/Bookmark_Dialog_Lat_Hint"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusBottomEnd="@dimen/corner_small"
            app:boxCornerRadiusBottomStart="@dimen/corner_small"
            app:boxCornerRadiusTopEnd="@dimen/corner_small"
            app:boxCornerRadiusTopStart="@dimen/corner_small">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/bookmark_lat_input"
                android:layout_width="match_parent"
                android:layout_height="@dimen/text_input_height"
                android:inputType="numberSigned|numberDecimal"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <Space
            android:layout_width="@dimen/spacing_sm"
            android:layout_height="@dimen/size_zero" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/bookmark_lng_layout"
            android:layout_width="@dimen/size_zero"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/Bookmark_Dialog_Lng_Hint"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusBottomEnd="@dimen/corner_small"
            app:boxCornerRadiusBottomStart="@dimen/corner_small"
            app:boxCornerRadiusTopEnd="@dimen/corner_small"
            app:boxCornerRadiusTopStart="@dimen/corner_small">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/bookmark_lng_input"
                android:layout_width="match_parent"
                android:layout_height="@dimen/text_input_height"
                android:inputType="numberSigned|numberDecimal"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/bookmark_notes_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:hint="@string/Bookmark_Dialog_Notes_Hint"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusBottomEnd="@dimen/corner_small"
        app:boxCornerRadiusBottomStart="@dimen/corner_small"
        app:boxCornerRadiusTopEnd="@dimen/corner_small"
        app:boxCornerRadiusTopStart="@dimen/corner_small">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/bookmark_notes_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="4"
            android:minLines="2" />
    </com.google.android.material.textfield.TextInputLayout>
</LinearLayout>
