<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/evidence_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/Evidence_Title"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textColor="?attr/colorOnSurface" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/Evidence_SelectModules"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/ev_cb_sessions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/Evidence_Cat_Sessions" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/ev_cb_routes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/Evidence_Cat_Routes" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/ev_cb_geofences"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/Evidence_Cat_GeoFences" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/ev_cb_permissions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/Evidence_Cat_Permissions" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/ev_cb_exif"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/Evidence_Cat_Exif" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/ev_cb_wipes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/Evidence_Cat_Wipes" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/Evidence_Format"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/evidence_format_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            app:checkedButton="@id/evidence_fmt_json"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/evidence_fmt_json"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="@dimen/size_zero"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/Evidence_Fmt_Json" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/evidence_fmt_csv"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="@dimen/size_zero"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/Evidence_Fmt_Csv" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/evidence_fmt_pdf"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="@dimen/size_zero"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/Evidence_Fmt_Pdf" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/evidence_generate_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/Evidence_Generate"
            app:icon="@drawable/ic_evidence_export" />

        <ProgressBar
            android:id="@+id/evidence_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/spacing_md"
            android:visibility="gone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/Evidence_History"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/evidence_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:nestedScrollingEnabled="false" />

        <LinearLayout
            android:id="@+id/evidence_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/spacing_xl"
            android:visibility="gone">

            <ImageView
                android:layout_width="@dimen/permission_illustration_size"
                android:layout_height="@dimen/permission_illustration_size"
                android:contentDescription="@string/Cd_EvidenceExport"
                android:src="@drawable/ic_evidence_export"
                app:tint="?attr/colorPrimary" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:gravity="center"
                android:text="@string/Evidence_Empty_Title"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:gravity="center"
                android:text="@string/Evidence_Empty_Body"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
