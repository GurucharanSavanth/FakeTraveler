    <!-- OEM battery optimization helper (FIX-011) -->
    <string name="OemHelper_Title">Background restrictions</string>
    <string name="OemHelper_OpenSettings">Open Settings</string>
    <string name="OemHelper_Xiaomi">MIUI / HyperOS aggressively kills background apps. Open Security → Permissions → Autostart and enable FakeTraveler, then exclude it from battery saver.</string>
    <string name="OemHelper_Samsung">One UI may put FakeTraveler to sleep after 3 days unused. Open Battery → Background usage limits and add FakeTraveler to \"Never sleeping apps\".</string>
    <string name="OemHelper_OnePlus">ColorOS gates background work behind \"App Auto Launch\". Open Privacy permissions → Startup manager and enable FakeTraveler.</string>
    <string name="OemHelper_Huawei">EMUI/HarmonyOS uses a \"Protected apps\" list. Open Battery → App launch and switch FakeTraveler to Manage manually with all three options enabled.</string>
    <string name="OemHelper_Vivo">FunTouch OS background restrictions vary. Open Battery → Background power usage and set FakeTraveler to \"Allow background activity\".</string>
    <string name="OemHelper_Generic">For mocking to survive screen-off and Doze, exempt FakeTraveler from battery optimization in system Settings.</string>

