    <string name="PermissionChecker_DialogMessage">FakeTraveler is not selected as the mock-location app.\n\nTo fix:\n1. Open Developer options.\n2. Find \"Select mock location app\".\n3. Choose FakeTraveler.\n\nIf Developer options are hidden: open About phone and tap Build number 7 times.</string>
