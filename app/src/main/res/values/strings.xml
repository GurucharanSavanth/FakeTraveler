    <!-- T1.3 OEM whitelist instructions -->
    <string name="Oem_Xiaomi_Instructions">Open Settings → Battery → Battery saver → tap FakeTraveler → set to No restrictions. On MIUI 12+: Settings → Apps → FakeTraveler → Battery saver → No restrictions.</string>
    <string name="Oem_Samsung_Instructions">Settings → Battery → Background usage limits → Never sleeping apps → add FakeTraveler.</string>
    <string name="Oem_OnePlus_Instructions">Settings → Battery → Battery optimization → FakeTraveler → Don\'t optimize. Plus: Settings → Apps → FakeTraveler → Battery → Allow background activity.</string>
    <string name="Oem_Vivo_Instructions">Settings → Battery → Background power consumption management → FakeTraveler → Allow.</string>
    <string name="Oem_Oppo_Instructions">Settings → Battery → Allow apps to run in background → FakeTraveler → On.</string>
    <string name="Oem_Realme_Instructions">Settings → Battery → App battery management → FakeTraveler → Allow background activity.</string>
    <string name="Oem_Huawei_Instructions">Settings → Battery → App launch → FakeTraveler → Manage manually → enable all toggles.</string>
    <string name="Oem_Generic_Instructions">Open Settings → Apps → FakeTraveler → Battery → Unrestricted.</string>
