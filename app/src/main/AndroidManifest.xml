<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:installLocation="internalOnly">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission
        android:name="android.permission.ACCESS_MOCK_LOCATION"
        tools:ignore="MockLocation,ProtectedPermissions" />
    <!-- Required by Android 14+ when foregroundServiceType="location" — we mock, not read,
         but the platform policy gates this permission on every foreground location service. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- P6–P8 Module 5: enumerate installed packages for the permission-drift audit.
         Play Store requires a sensitive-permission declaration; F-Droid is unaffected. -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />
    <!-- P6–P8 Module 6: read photos to strip GPS EXIF tags. -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- FIX-002 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- FIX-011: F-Droid friendly; Play submission may strip -->
    <uses-permission
        android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"
        tools:ignore="BatteryLife" />

    <!-- FIX-021 (drill-sergeant V19): signature-protected broadcast for in-app STOP control.
         Pre-33 registerReceiver gates on this permission; only our own PendingIntent (same signature)
         can dispatch ACTION_STOP_MOCK. On API 33+ Context.RECEIVER_NOT_EXPORTED is used instead. -->
    <permission
        android:name="cl.coders.faketraveler.permission.STOP_MOCK"
        android:protectionLevel="signature" />
    <uses-permission android:name="cl.coders.faketraveler.permission.STOP_MOCK" />

    <application
        android:name=".FakeTravelerApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="tiramisu"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <!-- T1.1 / V31: disable the default WorkManager initializer because
             FakeTravelerApplication implements Configuration.Provider. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" /></provider>
        <activity
            android:name="cl.coders.faketraveler.MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <data android:scheme="geo" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <data android:scheme="geo" />
                <data android:mimeType="*/*" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
            </intent-filter>

        </activity>

        <activity
            android:name=".AboutActivity"
            android:exported="false" />

        <!-- P6–P8 module activities -->
        <activity
            android:name=".RouteLabActivity"
            android:exported="false"
            android:resizeableActivity="true" />
        <activity
            android:name=".PermissionDriftActivity"
            android:exported="false"
            android:resizeableActivity="true" />
        <activity
            android:name=".EvidenceExportActivity"
            android:exported="false"
            android:resizeableActivity="true" />

        <!-- FIX-001 / FIX-002 -->
        <service
            android:name=".MockedLocationService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location" />

        <!-- FIX-005 -->
        <receiver
            android:name=".BootCompletedReceiver"
            android:enabled="true"
            android:exported="true"
            android:directBootAware="false"
            tools:ignore="UnusedAttribute">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </receiver>

        <!-- P6–P8 Module 8: share exported evidence files from app-private storage. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
